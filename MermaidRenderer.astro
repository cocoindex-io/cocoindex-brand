<script>
  // Hydrates the .mermaid-figure markup emitted by remark-mermaid.mjs. Lazily
  // imports mermaid (the consuming app provides it as a dependency) and themes
  // it from the brand CSS variables so diagrams match the surrounding page.
  // Drop <MermaidRenderer /> into any layout that renders mermaid fences.
  const renderMermaidDiagrams = async () => {
    const nodes = Array.from(document.querySelectorAll('.mermaid:not([data-processed="true"])'));
    if (nodes.length === 0) return;

    const { default: mermaid } = await import('mermaid');
    const styles = getComputedStyle(document.documentElement);

    // mermaid's color parser (khroma) only understands hex / rgb / hsl / named
    // colors — not oklch(), color-mix(), or color(srgb ...), which the brand
    // tokens use. Resolve each token to a plain #rrggbb so theming survives
    // whatever color space tokens.css happens to use. color-mix(in srgb, …)
    // forces an sRGB result the browser will serialize as rgb() or
    // color(srgb …); both are parsed back to hex here.
    const probe = document.createElement('span');
    probe.style.cssText = 'position:absolute;visibility:hidden;pointer-events:none';
    document.body.appendChild(probe);
    const hex2 = (x) => Math.max(0, Math.min(255, Math.round(x))).toString(16).padStart(2, '0');
    const toHex = (value) => {
      if (!value) return value;
      probe.style.color = '';
      probe.style.color = `color-mix(in srgb, ${value} 100%, ${value})`;
      const c = getComputedStyle(probe).color;
      let m = c.match(/^rgba?\(([^)]+)\)/);
      if (m) {
        const [r, g, b] = m[1].split(/[ ,/]+/).map(Number);
        return '#' + hex2(r) + hex2(g) + hex2(b);
      }
      m = c.match(/^color\(srgb\s+([^)]+)\)/);
      if (m) {
        const [r, g, b] = m[1].split(/[ /]+/).map(Number);
        return '#' + hex2(r * 255) + hex2(g * 255) + hex2(b * 255);
      }
      return value;
    };
    const cssVar = (name) => toHex(styles.getPropertyValue(name).trim());

    mermaid.initialize({
      startOnLoad: false,
      securityLevel: 'strict',
      theme: 'base',
      themeVariables: {
        background: cssVar('--paper'),
        primaryColor: cssVar('--cream'),
        primaryTextColor: cssVar('--maroon-ink'),
        primaryBorderColor: cssVar('--maroon'),
        lineColor: cssVar('--coral'),
        secondaryColor: cssVar('--cream-soft'),
        tertiaryColor: cssVar('--paper'),
        noteBkgColor: cssVar('--cream'),
        noteTextColor: cssVar('--maroon-ink'),
        noteBorderColor: cssVar('--coral'),
      },
    });
    probe.remove();

    try {
      await mermaid.run({ nodes });
    } catch (error) {
      console.error('Failed to render Mermaid diagram', error);
      nodes.forEach((node) => node.closest('.mermaid-figure')?.classList.add('mermaid-figure-error'));
    }
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', renderMermaidDiagrams, { once: true });
  } else {
    renderMermaidDiagrams();
  }
</script>
