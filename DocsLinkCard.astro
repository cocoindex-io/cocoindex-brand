---
/**
 * DocsLinkCard — inline link card for docs / external resources. Renders an <a>
 * with: icon disc · eyebrow · serif title (italic <em> accent) · description ·
 * arrow. Markup-only; styling is @cocoindex/brand/cards.css (`.docs-link-card`).
 * Reference: design_guidelines/ui/docs-link-card.html.
 *
 * `title` and `description` accept HTML (set via set:html) so authors can use
 * <em>…</em> in the title and <code>…</code> in the description.
 */
interface Props {
  href: string;
  title: string;
  description?: string;
  eyebrow?: string;
}

const { href, title, description, eyebrow = 'Documentation' } = Astro.props;
---
<a class="docs-link-card" href={href} rel="noopener">
  <span class="docs-link-card__ico" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
      <path d="M6.5 3h7.5l4 4v12.5A1.5 1.5 0 0 1 16.5 21h-10A1.5 1.5 0 0 1 5 19.5V4.5A1.5 1.5 0 0 1 6.5 3z"/>
      <path d="M14 3v5h5"/>
      <path d="M8.5 13h7M8.5 17h5"/>
    </svg>
  </span>
  <span class="docs-link-card__body">
    <span class="docs-link-card__eyebrow">{eyebrow}</span>
    <span class="docs-link-card__title" set:html={title}></span>
    {description && (
      <span class="docs-link-card__desc" set:html={description}></span>
    )}
  </span>
  <span class="docs-link-card__arrow" aria-hidden="true">→</span>
</a>
