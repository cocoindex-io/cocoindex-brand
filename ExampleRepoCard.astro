---
/**
 * ExampleRepoCard — inline link card pointing to a runnable GitHub example
 * folder. The whole card is one anchor; the "star us" pill on the right is a
 * decorative kicker. Markup-only; styling is @cocoindex/brand/cards.css
 * (`.example-repo-card`). Reference: design_guidelines/ui/example-repo-card.html.
 */
interface Props {
  href: string;
  path: string;
  description?: string;
  eyebrow?: string;
  starLabel?: string;
}

const {
  href,
  path,
  description,
  eyebrow = 'Example · GitHub',
  starLabel = 'star us',
} = Astro.props;
const external = /^https?:\/\//.test(href);
---
<a class="example-repo-card" href={href} {...(external ? { target: '_blank', rel: 'noopener' } : {})}>
  <span class="example-repo-card__ico" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor" aria-hidden="true">
      <path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56v-2.05c-3.2.7-3.88-1.36-3.88-1.36-.53-1.34-1.29-1.69-1.29-1.69-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.77 2.7 1.26 3.36.96.1-.75.4-1.26.73-1.55-2.55-.29-5.23-1.28-5.23-5.69 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.46.11-3.04 0 0 .97-.31 3.18 1.18a11.05 11.05 0 0 1 5.78 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.58.23 2.75.11 3.04.74.81 1.18 1.84 1.18 3.1 0 4.42-2.69 5.4-5.25 5.68.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.56C20.71 21.39 24 17.08 24 12 24 5.65 18.85.5 12 .5z"/>
    </svg>
  </span>
  <span class="example-repo-card__body">
    <span class="example-repo-card__eyebrow">{eyebrow}</span>
    <span class="example-repo-card__path">
      <code>{path}</code>
      <span class="example-repo-card__path-arrow" aria-hidden="true">→</span>
    </span>
    {description && (
      <span class="example-repo-card__desc" set:html={description}></span>
    )}
  </span>
  <span class="example-repo-card__star" aria-hidden="true">
    <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor" aria-hidden="true">
      <path d="M12 2.6l2.78 5.63 6.22.9-4.5 4.39 1.06 6.2L12 16.79 6.44 19.72 7.5 13.52 3 9.13l6.22-.9L12 2.6z"/>
    </svg>
    <span>{starLabel}</span>
  </span>
</a>
