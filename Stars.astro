---
// GitHub-stars pill/button — one shared component for every CocoIndex surface.
// Renders the star + count markup; style it via @cocoindex/brand/stars.css (the
// `.stars` nav pill) or compose any class (e.g. `.btn .btn-xl .hero-star`, or a
// site's `.star-pill`). A single bundled script fills the count for every
// <Stars> on the page — once per repo, sessionStorage-cached (1h). Renders
// "—" until the count loads.
// The canonical CocoIndex repo — the single config for every star count. Usages
// that show the main repo's stars omit `repo` and inherit this; only a pill for
// a *different* repo (e.g. cocoindex-code) passes `repo` explicitly. Change it
// here and every main-repo star count across all surfaces updates.
const DEFAULT_REPO = 'cocoindex-io/cocoindex';

interface Props {
  repo?: string;
  class?: string;
  label?: string;
  iconSize?: number;
  iconFilled?: boolean;
}
const {
  repo = DEFAULT_REPO,
  class: className = 'stars',
  label,
  iconSize = 14,
  iconFilled = false,
} = Astro.props;
---
<a class={className} href={`https://github.com/${repo}`} data-repo={repo} target="_blank" rel="noopener">
  <svg width={iconSize} height={iconSize} viewBox="0 0 24 24"
       fill={iconFilled ? 'currentColor' : 'none'} stroke="currentColor"
       stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
  </svg>
  {label && <span>{label}</span>}
  <span class="count">—</span>
</a>

<script>
  // Fill the star count for every <Stars> ([data-repo]) on the page — one fetch
  // per unique repo, sessionStorage-cached (1h TTL). Idempotent across renders.
  (() => {
    if (window.__cocoStarsInit) return;
    window.__cocoStarsInit = true;
    const TTL = 60 * 60 * 1000;
    const fmt = (n) =>
      n < 1000 ? n.toLocaleString()
      : n < 10000 ? `${(Math.round(n / 100) / 10).toFixed(1)}k`
      : `${Math.round(n / 1000)}k`;
    const setAll = (repo, count) => {
      document.querySelectorAll(`a[data-repo="${repo}"] .count`).forEach((el) => {
        el.textContent = fmt(count);
      });
    };
    const repos = [...new Set(
      [...document.querySelectorAll('a[data-repo]')].map((el) => el.getAttribute('data-repo')),
    )];
    repos.forEach((repo) => {
      try {
        const raw = sessionStorage.getItem(`gh-stars:${repo}`);
        if (raw) {
          const { count, ts } = JSON.parse(raw);
          if (Date.now() - ts < TTL && typeof count === 'number') { setAll(repo, count); return; }
        }
      } catch (e) { /* ignore */ }
      fetch(`https://api.github.com/repos/${repo}`)
        .then((r) => r.json())
        .then((d) => {
          if (typeof d.stargazers_count !== 'number') return;
          setAll(repo, d.stargazers_count);
          try {
            sessionStorage.setItem(`gh-stars:${repo}`, JSON.stringify({ count: d.stargazers_count, ts: Date.now() }));
          } catch (e) { /* quota / private mode */ }
        })
        .catch(() => { /* offline / rate-limited — leave the em-dash */ });
    });
  })();
</script>
