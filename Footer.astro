---
// THE site footer — one component, identical everywhere (home, blog, docs,
// examples). Links + logo are baked in as absolute cocoindex.io URLs so the
// exact same markup works from any surface, regardless of base path. Render it
// with no props: <Footer />. Styles: @cocoindex/brand/footer.css.
import Logo from './Logo.astro';

const SITE = 'https://cocoindex.io';

const COLS: { title: string; links: { label: string; href: string }[] }[] = [
  {
    title: 'Resources',
    links: [
      { label: 'Blog', href: `${SITE}/blogs/` },
      { label: 'Documentation', href: `${SITE}/docs/` },
      { label: 'YouTube', href: 'https://www.youtube.com/@cocoindex-io' },
      { label: 'Examples', href: `${SITE}/docs/examples/` },
      { label: 'Documentation (v0)', href: `${SITE}/docs-v0/` },
    ],
  },
  {
    title: 'Community',
    links: [
      { label: 'GitHub', href: 'https://github.com/cocoindex-io/cocoindex' },
      { label: 'Discord', href: 'https://discord.com/invite/zpA9S2DR7s' },
      { label: 'Twitter', href: 'https://x.com/cocoindex_io' },
      { label: 'LinkedIn', href: 'https://www.linkedin.com/company/cocoindex' },
    ],
  },
  {
    title: 'Company',
    links: [
      { label: 'Enterprise', href: `${SITE}/enterprise/` },
      { label: 'Careers', href: `${SITE}/careers/` },
      { label: 'Brand & press kit', href: `${SITE}/brand/` },
      { label: 'Privacy policy', href: `${SITE}/privacy-policy/` },
      { label: 'Terms of use', href: `${SITE}/terms-of-use/` },
      { label: 'hi@cocoindex.io', href: 'mailto:hi@cocoindex.io' },
    ],
  },
];
---

<footer class="it-foot">
  <!-- hum-07 footer: a big closing statement, then the brand + link meta row. -->
  <p class="foot-statement">Index once. <span class="hl">Stay fresh.</span></p>
  <div class="foot-grid">
    <div class="foot-brand">
      <Logo href={`${SITE}/`} src={`${SITE}/images/cocoindex.svg`} size="lg" />
      <p>Open-source · Apache-2.0</p>
    </div>
    {COLS.map((col) => (
      <div class="foot-col">
        <h6>{col.title}</h6>
        {col.links.map((l) => <a href={l.href}>{l.label}</a>)}
      </div>
    ))}
  </div>
  <div class="colo">
    <span>© 2026 CocoIndex</span>
    <span class="foot-tag">Source · Transform · Store · Sync</span>
  </div>
</footer>
